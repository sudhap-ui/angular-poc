# Environment Configuration
# Copy this file to .env and update values as needed

# API Configuration
NG_APP_API_URL=http://localhost:3000
NG_APP_API_TIMEOUT=30000

# Mock Server
NG_APP_MOCK_API_ENABLED=true
NG_APP_MOCK_API_PORT=3000

# Application
NG_APP_ENVIRONMENT=development
NG_APP_DEBUG=true

# Feature Flags
NG_APP_ENABLE_ANALYTICS=false
NG_APP_ENABLE_NOTIFICATIONS=true